    {
      "name": "Notifications — Create",
      "item": [
        {
          "name": "Create Single Notification (SMS)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.id) {",
                  "        pm.collectionVariables.set('notification_id', jsonData.data.id);",
                  "        console.log('Saved notification_id: ' + jsonData.data.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"recipient\": \"+0745123456\",\n    \"channel\": \"sms\",\n    \"content\": \"Marketing sms here!\",\n    \"priority\": \"high\",\n    \"idempotency_key\": \"notification-12345\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notifications"
              ]
            },
            "description": "Create a single SMS notification with high priority.\n\nAuto-saves the notification ID to the collection variable for use in subsequent requests."
          },
          "response": []
        },
