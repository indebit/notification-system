        {
          "name": "Create Batch (3 notifications)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.batch_id) {",
                  "        pm.collectionVariables.set('batch_id', jsonData.batch_id);",
                  "        console.log('Saved batch_id: ' + jsonData.batch_id);",
                  "    } else if (jsonData.data && jsonData.data.batch_id) {",
                  "        pm.collectionVariables.set('batch_id', jsonData.data.batch_id);",
                  "        console.log('Saved batch_id: ' + jsonData.data.batch_id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"notifications\": [\n        {\n            \"recipient\": \"+074513456\",\n            \"channel\": \"sms\",\n            \"content\": \"Hello! This is a testing SMS\",\n            \"priority\": \"high\",\n            \"scheduled_at\": \"2026-04-29 16:00:00\"\n        },\n        {\n            \"recipient\": \"john.snow@google.com\",\n            \"channel\": \"email\",\n            \"content\": \"I'm John Snow\",\n            \"priority\": \"normal\",\n            \"scheduled_at\": \"2026-04-29 16:00:00\"\n        },\n        {\n            \"recipient\": \"push-recipient-target\",\n            \"channel\": \"push\",\n            \"content\": \"You have a discount!\",\n            \"priority\": \"low\",\n            \"scheduled_at\": \"2026-04-29 16:00:00\"\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/batch",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notifications",
                "batch"
              ]
            },
            "description": "Create a batch of 3 notifications across different channels and priorities.\n\nAll notifications share the same batch_id.\n\nAuto-saves batch_id to collection variable."
          },
          "response": []
        }
      ]
    },
